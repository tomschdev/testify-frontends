# OAuth app credentials issued by the Alis identity service (users-v1).
#
# Register the app once, while signed in to the identity service in a browser:
#
#   https://users-v1-75542456563.europe-west1.run.app/apps/new
#     ?display_name=Attestant%20Profile
#     &redirect_uris=http://localhost:3000/auth/callback,https://<prod-domain>/auth/callback
#
# The resulting page shows the client_id and the client_secret. The secret is
# shown once only. Every redirect_uri the app will use must be listed on the
# app (a trailing `*` acts as a prefix wildcard) or /authorize rejects it.
AUTH_CLIENT_ID=
AUTH_CLIENT_SECRET=

# Google credentials used to call the backend Cloud Run gRPC services.
#
# The services' gRPC interceptor requires the `authorization` header to be a
# Google ID token whose email claim is the deployment service account,
# alis-build@<ALIS_OS_PROJECT>.iam.gserviceaccount.com. The signed-in user's
# JWT travels separately as x-alis-forwarded-authorization.
#
# Accepts either form of credential JSON (single line):
#   - a service account key for alis-build@... , or
#   - an external_account config (Workload Identity Federation) that
#     impersonates it — preferred, since it involves no long-lived key.
GCP_CREDENTIALS_JSON=

# Backend service overrides — all default to the deployed dev instances.
# AUTH_HOST=
# USERS_SERVICE=
# POSITIONS_SERVICE=
# PROFILES_SERVICE=
# ISSUE_SERVICE=
